<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Firetrack.Views.TransferPage"
             Title="Transfer Equipment">

    <VerticalStackLayout Padding="20" Spacing="20">
        <Label Text="Dual-Scan Handshake"
               FontSize="24"
               FontAttributes="Bold"
               HorizontalOptions="Center" />

        <Label Text="Step 1: Select Receiving Officer" FontSize="16" />
        <Picker Title="Select Officer"
                ItemsSource="{Binding Users}"
                ItemDisplayBinding="{Binding FullName}"
                SelectedItem="{Binding SelectedOfficer}" />

        <Label Text="Step 2: Identify Equipment" FontSize="16" />
        <Picker Title="Select Equipment"
                ItemsSource="{Binding EquipmentList}"
                ItemDisplayBinding="{Binding Name}"
                SelectedItem="{Binding SelectedEquipment}" />

        <Label Text="- OR -" HorizontalOptions="Center" FontAttributes="Italic" />

        <Entry Placeholder="Enter QR code manually"
               Text="{Binding ManualEquipmentQR}" />

        <Button Text="Transfer Equipment"
                Command="{Binding TransferCommand}"
                BackgroundColor="#4E6B94"
                TextColor="White"
                CornerRadius="10"
                HeightRequest="45" />

        <Label Text="{Binding StatusMessage}"
               TextColor="Green"
               HorizontalOptions="Center" />

        <Button Text="Back to Dashboard"
                Command="{Binding GoBackCommand}"
                BackgroundColor="Gray"
                TextColor="White"
                CornerRadius="10" />
    </VerticalStackLayout>
</ContentPage>