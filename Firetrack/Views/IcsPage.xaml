<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Firetrack.Views.IcsPage"
             Title="Generate ICS">

    <VerticalStackLayout Padding="20" Spacing="20">
        <Label Text="Inventory Custodian Slip (ICS)"
               FontSize="24"
               FontAttributes="Bold"
               HorizontalOptions="Center" />

        <!-- Equipment Details -->
        <Border Stroke="Gray" StrokeThickness="1" Padding="10" StrokeShape="RoundRectangle 10">
            <VerticalStackLayout Spacing="8">
                <Label Text="Equipment Details" FontAttributes="Bold" />
                <Label Text="{Binding Equipment.Name, StringFormat='Name: {0}'}" />
                <Label Text="{Binding Equipment.QRCode, StringFormat='QR Code: {0}'}" />
                <Label Text="{Binding Equipment.Type, StringFormat='Type: {0}'}" />
            </VerticalStackLayout>
        </Border>

        <!-- Custodian Details -->
        <Border Stroke="Gray" StrokeThickness="1" Padding="10" StrokeShape="RoundRectangle 10">
            <VerticalStackLayout Spacing="8">
                <Label Text="Custodian Details" FontAttributes="Bold" />
                <Label Text="{Binding Officer.FullName, StringFormat='Name: {0}'}" />
                <Label Text="{Binding Officer.Username, StringFormat='ID: {0}'}" />
                <Label Text="{Binding Officer.Role, StringFormat='Role: {0}'}" />
            </VerticalStackLayout>
        </Border>

        <!-- Issuing Officer -->
        <Border Stroke="Gray" StrokeThickness="1" Padding="10" StrokeShape="RoundRectangle 10">
            <VerticalStackLayout Spacing="8">
                <Label Text="Issuing Officer" FontAttributes="Bold" />
                <Label Text="{Binding Issuer.FullName, StringFormat='Name: {0}'}" />
                <Label Text="{Binding Issuer.Role, StringFormat='Position: {0}'}" />
            </VerticalStackLayout>
        </Border>

        <Label Text="{Binding StatusMessage}"
               TextColor="Green"
               HorizontalOptions="Center" />

        <Button Text="📄 Generate &amp; Download ICS"
                Command="{Binding GenerateIcsCommand}"
                BackgroundColor="#4E6B94"
                TextColor="White"
                CornerRadius="10"
                HeightRequest="45" />

        <Button Text="Back"
                Command="{Binding GoBackCommand}"
                BackgroundColor="Gray"
                TextColor="White"
                CornerRadius="10" />

        <ActivityIndicator IsRunning="{Binding IsBusy}"
                           Color="#4E6B94" />
    </VerticalStackLayout>
</ContentPage>