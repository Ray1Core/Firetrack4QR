<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Firetrack.Views.ReportDamagePage"
             Title="Report Damage">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <!-- Header -->
            <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                <Label Text="⚠️ Report Damaged Equipment"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="{StaticResource PrimaryColor}"
                       HorizontalOptions="Center" />
                <Label Text="Provide details and attach a photo."
                       FontSize="14"
                       TextColor="{StaticResource TextSecondaryColor}"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- Equipment Details Card -->
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="5">
                    <Label Text="Equipment Details"
                           FontAttributes="Bold"
                           FontSize="16"
                           TextColor="{StaticResource PrimaryColor}" />
                    <Label Text="{Binding Equipment.Name, StringFormat='Name: {0}'}" />
                    <Label Text="{Binding Equipment.QRCode, StringFormat='QR Code: {0}'}" />
                    <Label Text="{Binding Equipment.Type, StringFormat='Type: {0}'}" />
                    <Label Text="{Binding Equipment.AssignedToUsername, StringFormat='Assigned To: {0}'}" />
                </VerticalStackLayout>
            </Border>

            <!-- Photo Section Card -->
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Damage Photo"
                           FontAttributes="Bold"
                           FontSize="16"
                           TextColor="{StaticResource PrimaryColor}" />

                    <Border HeightRequest="200"
                            BackgroundColor="#F0F0F0"
                            Padding="0"
                            HorizontalOptions="Fill"
                            StrokeThickness="0">
                        <Image Source="{Binding PhotoPreview}"
                               Aspect="AspectFit"
                               HorizontalOptions="Center" />
                    </Border>

                    <Button Text="📷 Select Photo"
                            Command="{Binding PickPhotoCommand}"
                            Style="{StaticResource PrimaryButton}" />
                </VerticalStackLayout>
            </Border>

            <!-- Remarks Card -->
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Remarks"
                           FontAttributes="Bold"
                           FontSize="16"
                           TextColor="{StaticResource PrimaryColor}" />
                    <Editor Placeholder="Describe the damage..."
                            Text="{Binding Remarks}"
                            HeightRequest="100"
                            BackgroundColor="White"
                            TextColor="{StaticResource TextPrimaryColor}"
                            PlaceholderColor="{StaticResource TextSecondaryColor}" />
                </VerticalStackLayout>
            </Border>

            <!-- Status Message -->
            <Label Text="{Binding StatusMessage}"
                   TextColor="{Binding StatusMessage, Converter={StaticResource StringToColorConverter}}"
                   HorizontalOptions="Center"
                   FontSize="14" />

            <!-- Buttons -->
            <Button Text="Submit Report"
                    Style="{StaticResource DangerButton}"
                    Command="{Binding SubmitReportCommand}" />

            <Button Text="Back"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding GoBackCommand}" />

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               Color="{StaticResource PrimaryColor}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>