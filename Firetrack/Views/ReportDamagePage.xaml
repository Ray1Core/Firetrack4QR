<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Firetrack.Views.ReportDamagePage"
             Title="Report Damage">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <Label Text="Report Damaged Equipment"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <!-- Equipment details (use Border) -->
            <Border Stroke="Gray" StrokeThickness="1" Padding="10" StrokeShape="RoundRectangle 10">
                <VerticalStackLayout Spacing="5">
                    <Label Text="Equipment Details" FontAttributes="Bold" />
                    <Label Text="{Binding Equipment.Name, StringFormat='Name: {0}'}" />
                    <Label Text="{Binding Equipment.QRCode, StringFormat='QR Code: {0}'}" />
                    <Label Text="{Binding Equipment.Type, StringFormat='Type: {0}'}" />
                    <Label Text="{Binding Equipment.AssignedToUsername, StringFormat='Assigned To: {0}'}" />
                </VerticalStackLayout>
            </Border>

            <!-- Photo section (use Border) -->
            <Border Stroke="Gray" StrokeThickness="1" Padding="10" StrokeShape="RoundRectangle 10">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Damage Photo" FontAttributes="Bold" />

                    <Border HeightRequest="200" 
                            BackgroundColor="#F0F0F0"
                            Padding="0"
                            HorizontalOptions="Fill">
                        <Image Source="{Binding PhotoPreview}" 
                               Aspect="AspectFit"
                               HorizontalOptions="Center">
                            <!-- Remove trigger or add placeholder image -->
                        </Image>
                    </Border>

                    <Button Text="📷 Select Photo"
                            Command="{Binding PickPhotoCommand}"
                            BackgroundColor="#4E6B94"
                            TextColor="White"
                            CornerRadius="10" />
                </VerticalStackLayout>
            </Border>

            <!-- Remarks (use Border) -->
            <Border Stroke="Gray" StrokeThickness="1" Padding="10" StrokeShape="RoundRectangle 10">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Remarks" FontAttributes="Bold" />
                    <Editor Placeholder="Describe the damage..."
                            Text="{Binding Remarks}"
                            HeightRequest="100" />
                </VerticalStackLayout>
            </Border>

            <!-- Status message -->
            <Label Text="{Binding StatusMessage}"
                   TextColor="Green"
                   HorizontalOptions="Center" />

            <!-- Buttons -->
            <Button Text="Submit Report"
                    Command="{Binding SubmitReportCommand}"
                    BackgroundColor="#D32F2F"
                    TextColor="White"
                    CornerRadius="10"
                    HeightRequest="45" />

            <Button Text="Back"
                    Command="{Binding GoBackCommand}"
                    BackgroundColor="Gray"
                    TextColor="White"
                    CornerRadius="10" />

            <!-- Activity indicator -->
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               Color="#4E6B94" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>