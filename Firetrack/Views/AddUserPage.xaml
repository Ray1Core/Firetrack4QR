<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Firetrack.Views.AddUserPage"
             Title="Add User">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <!-- Header -->
            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                <Label Text="👤 Create New Account"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="{StaticResource PrimaryColor}"
                       HorizontalOptions="Center" />
                <Label Text="Fill in the details to add a new user."
                       FontSize="14"
                       TextColor="{StaticResource TextSecondaryColor}"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- Form Card -->
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="16">
                    <Entry Style="{StaticResource EntryStyle}"
                           Placeholder="Username"
                           Text="{Binding Username}" />

                    <Entry Style="{StaticResource EntryStyle}"
                           Placeholder="Password"
                           IsPassword="True"
                           Text="{Binding Password}" />

                    <Entry Style="{StaticResource EntryStyle}"
                           Placeholder="Full Name"
                           Text="{Binding FullName}" />

                    <Picker Title="Select Role"
                            ItemsSource="{Binding Roles}"
                            SelectedItem="{Binding Role}"
                            TextColor="{StaticResource TextPrimaryColor}"
                            TitleColor="{StaticResource TextSecondaryColor}" />

                    <Label Text="{Binding StatusMessage}"
                           TextColor="{Binding StatusMessage, Converter={StaticResource StringToColorConverter}}"
                           HorizontalOptions="Center"
                           FontSize="14" />

                    <Button Text="Create Account"
                            Style="{StaticResource SuccessButton}"
                            Command="{Binding SaveUserCommand}" />

                    <Button Text="Cancel"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding CancelCommand}" />

                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       Color="{StaticResource PrimaryColor}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>